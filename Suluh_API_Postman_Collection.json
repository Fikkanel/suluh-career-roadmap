    {
      "name": "7. Karir Publik (API Key Auth)",
      "description": "Endpoint untuk data publik yang dilindungi dengan API Key.\n\n**Auth:** Header `X-API-KEY: {{api_key}}`",
      "item": [
        {
          "name": "GET Daftar Semua Karir",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-API-KEY",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/careers",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "careers"]
            },
